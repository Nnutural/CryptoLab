# Force npm artifacts to stay inside the project directory. Combined with
# scripts/env.sh exporting NPM_CONFIG_CACHE/PREFIX, this guarantees that
# `npm install` never writes to ~/.npm.

cache=../.npm-cache
prefix=../.npm-global
fund=false
audit=false
update-notifier=false

# Faster CI installs once we have a lockfile.
prefer-offline=true
