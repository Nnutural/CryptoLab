{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-6",
  "permissions": {
    "allow": [
      "Bash(cargo fmt:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo bench:*)",
      "Bash(cargo doc:*)",
      "Bash(rustc --version)",
      "Bash(rustup show)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mypy:*)",
      "Bash(uvicorn:*)",
      "Bash(alembic:*)",
      "Bash(pip install:*)",
      "Bash(uv:*)",
      "Bash(maturin:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(node --version)",
      "Bash(bash scripts/*)",
      "Bash(docker compose:*)",
      "Bash(docker build:*)",
      "Bash(docker ps)",
      "Bash(docker logs:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(sudo rm:*)",
      "Bash(cargo install --root *)",
      "Bash(pip install --user:*)",
      "Bash(npm install -g:*)",
      "Bash(rustup --default-toolchain *)"
    ]
  },
  "ignorePatterns": [
    "target/",
    "node_modules/",
    ".venv/",
    "__pycache__/",
    ".cargo-home/",
    ".rustup-home/",
    ".npm-cache/",
    ".npm-global/",
    "*.so",
    "*.pyd",
    "pgdata/",
    "redisdata/",
    "dist/",
    "frontend/dist/"
  ],
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  }
}
