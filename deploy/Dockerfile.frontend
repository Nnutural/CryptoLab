FROM node:20-alpine AS builder
WORKDIR /app

COPY package.json .npmrc ./
RUN npm install --no-audit --no-fund

COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
# A simple default; nginx-side TLS termination lives in the top-level `nginx` service.
RUN printf 'server { listen 80; root /usr/share/nginx/html; try_files $uri /index.html; }\n' \
        > /etc/nginx/conf.d/default.conf
EXPOSE 80
