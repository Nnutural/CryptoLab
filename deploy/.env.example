# Copy to deploy/.env and edit. NEVER commit deploy/.env.

POSTGRES_DB=cryptolab
POSTGRES_USER=cryptolab
POSTGRES_PASSWORD=change-me-strong-password

# 32-byte JWT signing key. Generate via: openssl rand -hex 32
JWT_SECRET=change-me-32-byte-hex

# 32-byte master KEK used to wrap private key material at rest.
# Generate via: openssl rand -hex 32
MASTER_KEY_HEX=change-me-32-byte-hex

CRYPTOLAB_ENVIRONMENT=staging
